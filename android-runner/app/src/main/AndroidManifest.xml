<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest additions for the HermesAPIPlugin and the
  GatewayForegroundService / BootReceiver. This file is *merged* into
  the Capacitor-generated AndroidManifest.xml by `cap sync android`.
  Do not put application-level entries here; only <service>,
  <receiver>, and <uses-permission> tags that the merge step will
  combine with the default Capacitor manifest.

  Run `bash apps/mobile/scripts/setup-android.sh` after the first
  `npx cap add android` to copy this fragment into the generated
  project, and to register HermesAPIPlugin in MainActivity.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.nousresearch.hermes"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network for chat / API / remote mode -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service — specialUse for long-running agent gateway -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Phase 4: file picker + voice capture + share + biometric -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!--
      Workstream C: Termux RUN_COMMAND IPC. We dispatch shell
      commands into Termux's $PREFIX via RunCommandService and get
      stdout/stderr/exit-code back via RUN_COMMAND_PENDING_INTENT
      (requires Termux >= 0.109). The signature-level permission
      must be requested here and granted by the user once in
      Android Settings -> App info -> Additional permissions.
    -->
    <uses-permission android:name="com.termux.permission.RUN_COMMAND" />

    <!--
      Workstream C: package visibility on Android 11+ (API 30+).
      Without this <queries> block, PackageManager.getPackageInfo
      (used by TermuxProbe.isTermuxInstalled) throws
      NameNotFoundException even when Termux is installed,
      defeating the entire backend-selection logic in
      HermesInstaller.currentBackend(). We declare visibility for
      both the Termux package itself and the RUN_COMMAND intent
      action (the latter is what we actually dispatch).
    -->
    <queries>
        <package android:name="com.termux" />
        <package android:name="com.termux.api" />
        <intent>
            <action android:name="com.termux.RUN_COMMAND" />
        </intent>
    </queries>

    <!--
      Long-running AI gateway foreground service. The
      `foregroundServiceType="specialUse"` requires a justification
      property, declared inline below. Android 14+ (UPSIDE_DOWN_CAKE)
      strictly enforces that the runtime ServiceInfo type matches the
      manifest; we pass `FOREGROUND_SERVICE_TYPE_SPECIAL_USE` from
      GatewayForegroundService.startInForeground().
    -->
    <service
        android:name=".GatewayForegroundService"
        android:enabled="true"
        android:exported="false"
        android:foregroundServiceType="specialUse">
        <property
            android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
            android:value="Long-running AI agent gateway with HTTP/SSE chat, scheduled cron tasks, and 16 messaging platform integrations. Killing the process terminates the user's assistant and breaks the user-facing chat UI." />
    </service>

    <!--
      Boot autostart receiver. Opt-in: only fires the foreground
      service if the user has flipped the "start on boot" toggle in
      the renderer's Settings screen. Must be exported so the system
      can deliver the BOOT_COMPLETED broadcast; we don't accept any
      other actions.
    -->
    <receiver
        android:name=".BootReceiver"
        android:enabled="true"
        android:exported="true"
        tools:ignore="ExportedReceiver">
        <intent-filter android:priority="1000">
            <action android:name="android.intent.action.BOOT_COMPLETED" />
            <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
        </intent-filter>
    </receiver>

    <!--
      v0.1.0: SshTunnelService is a plain helper class
      (instantiated by HermesApi as `SshTunnelService(context)`),
      not a real android.app.Service. The previous manifest entry
      was a Phase A leftover that AGP's instantiability check
      rejected. The class is still used as a helper for managing
      the SSH child process; only the manifest registration is
      dropped. The Kotlin class itself is unchanged.
    -->

    <!--
      Phase A: OAuth device-code browser activity. Generates a CSRF
      state token, saves it to hermes_oauth prefs, launches the
      system browser against the auth URL. The `hermes://oauth-
      callback?code=...&state=...` deep link is delivered to
      MainActivity (which carries the intent-filter in the live
      manifest's <application> block); MainActivity.onNewIntent
      routes it to HermesApi.handleOAuthCallback. We do NOT
      attach the intent-filter here — the device-code flow's
      target is MainActivity, not this activity.
    -->
    <activity
        android:name=".OAuthBrowserActivity"
        android:enabled="true"
        android:exported="true" />

</manifest>
