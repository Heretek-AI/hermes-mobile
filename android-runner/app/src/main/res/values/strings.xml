<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Hermes Agent</string>

    <!-- Foreground service notification (Phase 3) -->
    <string name="gateway_notif_title">Hermes Agent</string>
    <string name="gateway_notif_text">Gateway running on localhost:8642</string>
    <string name="gateway_notif_action_stop">Stop</string>
    <string name="gateway_notif_action_open">Open Hermes</string>

    <!--
      Termux install CTAs. Surfaced from WelcomeScreen.kt's middle
      InstallOptionCard when TermuxProbe reports Termux is not
      installed. F-Droid is the primary action because the Play
      Store build of Termux was abandoned years ago and is
      incompatible with current Termux:API; GitHub Releases is the
      side-load fallback. The Phase-2 missing-Termux dialog strings
      are kept for future use (e.g. a snackbar from the install
      stage if Termux disappears mid-install).
    -->
    <string name="termux_missing_title">Termux Required</string>
    <string name="termux_missing_message">To run hermes-agent locally on Android, install Termux and Termux:API from F-Droid. Then return to Hermes to continue.</string>
    <string name="termux_install_action">Open F-Droid</string>
    <string name="termux_install_github">Or get it from GitHub Releases</string>

    <!--
      Workstream C (RESULT_INTENT wiring). Surfaced from InstallScreen
      when an install stage fails with ERR != RESULT_OK, which Termux's
      RunCommandService returns when our app lacks
      com.termux.permission.RUN_COMMAND or when Termux's
      ~/.termux/termux.properties does not have
      allow-external-apps=true. The "Open App Settings" button uses
      HermesApi.openExternal with package:com.nousresearch.hermes so
      the user lands directly on the Additional Permissions screen.
    -->
    <string name="termux_permission_needed_title">Termux setup needed</string>
    <string name="termux_permission_needed_message">Hermes needs four things from your Termux install before the local install can run. Do these in order, then tap Retry:\n\n1. Install Termux and (recommended) Termux:API from F-Droid. Termux:API powers the battery / sensor / telephony features Hermes uses after install.\n\n2. Grant the “Run commands inside Termux environment” permission: tap Open App Settings → Additional permissions → enable it.\n\n3. In Termux, enable external apps: long-press the Termux screen → Properties → toggle “allow-external-apps” (or run `echo allow-external-apps=true >> ~/.termux/termux.properties` then `termux-reload-settings`).\n\n4. Return to Hermes and tap Retry.</string>
    <string name="termux_permission_open_settings">Open App Settings</string>

    <!--
      Pinned hermes-agent SHA. Updated by bumping
      apps/mobile/scripts/hermes-agent-version.txt and re-running
      `bash apps/mobile/scripts/setup-android.sh`. HermesInstaller
      reads this at git-clone time and at runHermesUpdate time.
    -->
    <string name="hermes_agent_pinned_sha">e7bc6189cf185f9c223a4428115147e483d9ff89</string>

    <!--
      Termux preflight wizard (Phase 9). Surfaced from
      TermuxPreflightScreen.kt, which runs after the user picks
      "Install locally (Termux)" on WelcomeScreen and before the
      8-stage installer. The wizard walks the user through
      installing Termux, granting com.termux.permission.RUN_COMMAND,
      enabling allow-external-apps=true, and verifying the
      property stuck. Strings are intentionally verbose so the
      user never has to consult external docs.
    -->
    <string name="preflight_title">Termux setup</string>
    <string name="preflight_subtitle">A few quick steps so Hermes can run inside Termux.</string>
    <string name="preflight_step_label">Step %1$d of %2$d</string>

    <!-- Step 1: install Termux from F-Droid -->
    <string name="preflight_step1_title">Install Termux</string>
    <string name="preflight_step1_body_installed">Termux %1$s detected. Tap Continue.</string>
    <string name="preflight_step1_body_missing">Hermes runs inside Termux on Android. Install Termux from F-Droid (the only official source) and return here.</string>
    <string name="preflight_step1_waiting">Waiting for Termux to appear…</string>
    <string name="preflight_step1_timeout">Still not detected? Make sure the install finished and try again.</string>
    <string name="preflight_step1_check_again">Check again</string>
    <string name="preflight_action_continue">Continue</string>

    <!-- Step 2: grant com.termux.permission.RUN_COMMAND in Android Settings -->
    <string name="preflight_step2_title">Grant permission</string>
    <string name="preflight_step2_body">Hermes needs the “Run commands inside Termux environment” permission from Android. Tap Open App Settings → Additional permissions → enable it, then return here.</string>
    <string name="preflight_step2_body_verified">Permission granted. Tap Continue.</string>

    <!-- Step 3: enable allow-external-apps=true in ~/.termux/termux.properties -->
    <string name="preflight_step3_title">Allow external apps</string>
    <string name="preflight_step3_body_auto">Setting `allow-external-apps=true` in Termux…</string>
    <string name="preflight_step3_caption">Command: writes `allow-external-apps=true` to `~/.termux/termux.properties` and reloads Termux settings.</string>
    <string name="preflight_step3_error_title">Auto-set failed</string>
    <string name="preflight_action_copy_command">Copy command</string>
    <string name="preflight_action_copied">Copied</string>
    <string name="preflight_action_i_did_it">I did it</string>

    <!-- Step 4: verify the property stuck -->
    <string name="preflight_step4_title">Verifying…</string>
    <string name="preflight_step4_body_verified">Verified: `allow-external-apps=true` is set in Termux.</string>
    <string name="preflight_step4_error_title">Property not set</string>
    <string name="preflight_step4_error_body">We couldn’t read `allow-external-apps=true` from `~/.termux/termux.properties`. Go back to step 3 and try again.</string>
    <string name="preflight_action_back_to_step_3">Back to step 3</string>

    <!-- Step 5: choose install path (in-app 8-stage or one-line docs) -->
    <string name="preflight_step5_title">Install Hermes</string>
    <string name="preflight_step5_body">Pick how to install Hermes inside Termux.</string>
    <string name="preflight_action_run_in_app">Run Hermes installer</string>
    <string name="preflight_action_run_one_liner">Use one-line installer</string>
    <string name="preflight_action_why_both">Why both?</string>
    <string name="preflight_why_both_body">The in-app installer shows progress and lets you retry failed stages. The one-line installer is the canonical desktop path and is useful if our installer hits an edge case we don’t cover.</string>
    <string name="preflight_action_back">Back</string>
</resources>
