{
  "name": "@hermes/ipc",
  "version": "0.1.0",
  "private": true,
  "description": "Typed IPC contract shared between hermes-desktop and hermes-mobile. Source of truth for window.hermesAPI surface.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./mobile": {
      "types": "./dist/mobile.d.ts",
      "import": "./dist/mobile.js"
    },
    "./desktop": {
      "types": "./dist/desktop.d.ts",
      "import": "./dist/desktop.js"
    },
    "./web-fallback": {
      "types": "./dist/web-fallback.d.ts",
      "import": "./dist/web-fallback.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@capacitor/core": "^7.2.0",
    "typescript": "^5.9.3"
  }
}
