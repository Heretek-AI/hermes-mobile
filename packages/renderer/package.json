{
  "name": "@hermes/renderer",
  "version": "0.1.0",
  "private": true,
  "description": "Vendored React renderer from hermes-desktop. Re-exports App as a single import target for the mobile shell.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@hermes/ipc": "workspace:*",
    "@types/highlight.js": "^10.1.0",
    "@wesbos/code-icons": "^1.2.4",
    "highlight.js": "^11.11.1",
    "i18next": "^25.6.0",
    "lucide-react": "^1.7.0",
    "react-i18next": "^15.7.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3"
  }
}
